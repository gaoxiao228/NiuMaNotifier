{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NiumaNotifier",
  "version": "0.1.0",
  "identifier": "dev.niuma.notifier",
  "build": {
    "beforeDevCommand": "npm run build:codex-plugin && npm run dev",
    "devUrl": "http://localhost:58415",
    "beforeBuildCommand": "npm run build:codex-plugin:release && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NiumaNotifier",
        "width": 960,
        "height": 640
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
