{
  "name": "niuma-remote-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "npm run build && npm test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "sh -c 'if [ -f dist/db/migrate.js ]; then node dist/db/migrate.js; else tsx src/db/migrate.ts; fi'",
    "admin:bootstrap": "sh -c 'if [ -f dist/db/bootstrap-admin.js ]; then node dist/db/bootstrap-admin.js; else tsx src/db/bootstrap-admin.ts; fi'",
    "devices:dedupe": "node scripts/dedupe-devices.mjs",
    "smoke:remote": "node scripts/remote-smoke.mjs"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.2",
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.39.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
